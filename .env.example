# URL Audit Kit
#
# For local development with Next.js, put these in `frontend/.env.local`.
# For Render, add them as service environment variables in the dashboard or render.yaml.

URL_AUDIT_DB_PATH=./data/url_audit.db
GOOGLE_SAFE_BROWSING_API_KEY=
AI_PROVIDER=nim
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_MODEL=meta/llama-3.1-70b-instruct
NVIDIA_NIM_TIMEOUT=90

# Legacy aliases still accepted by the app:
# NVIDIA_TEXT_MODEL=
# NVIDIA_TIMEOUT=
